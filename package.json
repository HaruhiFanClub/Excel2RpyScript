{
  "name": "excel2rpy",
  "private": true,
  "version": "1.0.0",
  "description": "Excel→RenPy 转换 + 批量 TTS 的现代化 Electron 桌面应用",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.11.0"
  },
  "scripts": {
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "build": "pnpm -r --if-present build",
    "release": "node scripts/release.mjs",
    "release:dry-run": "node scripts/release.mjs --dry-run",
    "ci:compose-latest": "node scripts/ci-compose-latest-json.mjs",
    "ci:upload-r2": "node scripts/ci-upload-r2.mjs",
    "ci:prune-r2": "node scripts/ci-prune-r2.mjs",
    "ci:purge-cf": "node scripts/ci-purge-cf.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1063.0"
  }
}
